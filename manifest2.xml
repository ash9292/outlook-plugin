<?xml version="1.0" encoding="UTF-8"?>

<OfficeApp
    xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
    xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="MailApp">

  <Id>c9f4c3e1-1111-2222-3333-444444444003</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Thread Reader</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="Thread Reader"/>
  <Description DefaultValue="Read email thread"/>

  <IconUrl DefaultValue="https://ash9292.github.io/outlook-plugin/emailthread.png"/>
  <HighResolutionIconUrl DefaultValue="https://ash9292.github.io/outlook-plugin/emailthread.png"/>
  <SupportUrl DefaultValue="https://ash9292.github.io/outlook-plugin"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ash9292.github.io/outlook-plugin/taskpane3.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs"
          ItemType="Message"
          FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- Correct VersionOverrides -->
  <VersionOverrides
      xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
      xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">

        <DesktopFormFactor>

          <FunctionFile resid="functionFile"/>

          <ExtensionPoint xsi:type="MessageReadCommandSurface">

            <OfficeTab id="TabDefault">

              <Group id="threadGroup">
                <Label resid="groupLabel"/>

                <Control xsi:type="Button" id="threadButton">

                  <Label resid="buttonLabel"/>

                  <Supertip>
                    <Title resid="buttonLabel"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>

                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>

                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>

                </Control>

              </Group>

            </OfficeTab>

          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>
    </Hosts>

    <Resources>

      <bt:Images>
        <bt:Image id="icon16"
          DefaultValue="https://ash9292.github.io/outlook-plugin/emailthread.png"/>
        <bt:Image id="icon32"
          DefaultValue="https://ash9292.github.io/outlook-plugin/emailthread.png"/>
        <bt:Image id="icon80"
          DefaultValue="https://ash9292.github.io/outlook-plugin/emailthread.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="taskpaneUrl"
          DefaultValue="https://ash9292.github.io/outlook-plugin/taskpane3.html"/>

        <bt:Url id="functionFile"
          DefaultValue="https://ash9292.github.io/outlook-plugin/taskpane3.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Thread Tools"/>
        <bt:String id="buttonLabel" DefaultValue="Open Thread"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="buttonDesc"
          DefaultValue="Open email thread details"/>
      </bt:LongStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>